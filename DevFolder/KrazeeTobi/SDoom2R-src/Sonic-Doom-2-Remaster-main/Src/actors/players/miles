{
  Speed 1
  Health 100
  Radius 16
  Height 56
  Mass 100
  PainChance 255
  Player.DisplayName "Tails"
  Player.StartItem "Pistol"
  Player.StartItem "Fist"
  Player.Face "TAL"
  Player.StartItem "Clip", 50
  Player.WeaponSlot 1, Fist, Chainsaw
  Player.WeaponSlot 2, Pistol
  Player.WeaponSlot 3, Shotgun, SuperShotgun
  Player.WeaponSlot 4, Chaingun
  Player.WeaponSlot 5, RocketLauncher
  Player.WeaponSlot 6, PlasmaRifle
  Player.WeaponSlot 7, BFG9000
  Player.ColorRange 112, 127
  Player.ColorSet 0, "Green",         0x70, 0x7F,  0x72
  Player.ColorSet 1, "Gray",          0x60, 0x6F,  0x62 // Called "Indigo" originally so as to have a unique initial
  Player.ColorSet 2, "Brown",         0x40, 0x4F,  0x42
  Player.ColorSet 3, "Red",           0x20, 0x2F,  0x22
  // Doom Legacy additions
  Player.ColorSet 4, "Light Gray",    0x58, 0x67,  0x5A
  Player.ColorSet 5, "Light Brown",   0x38, 0x47,  0x3A
  Player.ColorSet 6, "Light Red",     0xB0, 0xBF,  0xB2
  Player.ColorSet 7, "Light Blue",    0xC0, 0xCF,  0xC2

  States
  {
  Spawn:
    TALP A -1
    Loop
  See:
    TALP ABCD 4 
    Loop
  Missile:
    TALP E 12
    Goto Spawn
  Melee:
    TALP F 6 BRIGHT
    Goto Missile
  Pain:
    TALP G 4 
    TALP G 4 A_Pain
    Goto Spawn
  Death:
    TALP H 0 A_PlayerSkinCheck("AltSkinDeath")
  Death1:
    TALP H 10
    TALP I 10 A_PlayerScream
    TALP J 10 A_NoBlocking
    TALP KLM 10
    TALP N -1
    Stop
  XDeath:
    TALP O 0 A_PlayerSkinCheck("AltSkinXDeath")
  XDeath1:
    TALP O 5
    TALP P 5 A_XScream
    TALP Q 5 A_NoBlocking
    TALP RSTUV 5
    TALP W -1
    Stop
  AltSkinDeath:
    TALP H 6
    TALP I 6 A_PlayerScream
    TALP JK 6
    TALP L 6 A_NoBlocking
    TALP MNO 6
    TALP P -1
    Stop
  AltSkinXDeath:
    TALP Q 5 A_PlayerScream
    TALP R 0 A_NoBlocking
    TALP R 5 A_SkullPop
    TALP STUVWX 5
    TALP Y -1
    Stop
  }
}
